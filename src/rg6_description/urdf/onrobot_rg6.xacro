<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:macro name="onrobot_rg6_base_link" params="prefix">
    <link name="${prefix}onrobot_rg6_base_link">
      <inertial>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
        <mass value="0.7" />
        <inertia ixx="1.0E-03" ixy="1.0E-06" ixz="1.0E-06" iyy="1.0E-03" iyz="1.0E-06" izz="1.0E-03" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://rg6_description/meshes/visual/base_link.stl" />
        </geometry>
        <material name="rg6_silver">
          <color rgba="0.6 0.6 0.6 1" />
        </material>
      </visual>
      <!-- NUR NOCH die Gehaeuse-Huell-Box (Greifer-Koerper / Motorhaus) an
           DIESEM Link. Frueher gab es zusaetzlich eine statische Finger-Huell-Box
           (Union ueber den ganzen Fingerhub, origin 0 0 0.205, 0.036x0.166x0.170),
           fest am base_link -> hat jeden Zugriff *zwischen* die Pads blockiert, so
           dass Greifen im Planer unmoeglich war. Die Finger haben jetzt eigene
           artikulierte Collision (onrobot_rg6_model_macro.xacro), die sich mit dem
           Greifhub bewegt; die Intra-Greifer-Self-Collision wird per SRDF via
           rg6_moveit_patch deaktiviert.
           Gehaeuse-Masse aus den Visual-Meshes vermessen (twinlink/MuJoCo),
           Marge ~5 mm: x[-0.036,+0.040] y[+-0.042] z[0..0.167].
           Box startet bei z=0.02 -> reicht NICHT in arm_0_wrist_3_link zurueck
           (kein Handgelenk-Falschtreffer). D435 (camera_0_link) sitzt auf der
           Gehaeuse-Oberseite (robot.yaml: parent base_link, xyz 0.023/0/0.14) ->
           base<->camera ist im SRDF 'Adjacent' deaktiviert. -->
      <collision>
        <origin xyz="0.002 0 0.095" rpy="0 0 0"/>
        <geometry>
          <box size="0.086 0.094 0.150"/>
        </geometry>
      </collision>
    </link>
  </xacro:macro>

  <xacro:macro name="finger_joints" params="prefix fingerprefix reflect">
    <xacro:inner_knuckle_joint prefix="${prefix}" fingerprefix="${fingerprefix}" reflect="${reflect}"/>
    <xacro:inner_finger_joint prefix="${prefix}" fingerprefix="${fingerprefix}"/>
  </xacro:macro>

  <xacro:macro name="finger_links" params="prefix fingerprefix">
    <xacro:outer_knuckle prefix="${prefix}" fingerprefix="${fingerprefix}"/>
    <xacro:inner_knuckle prefix="${prefix}" fingerprefix="${fingerprefix}"/>
    <xacro:inner_finger prefix="${prefix}" fingerprefix="${fingerprefix}"/>
  </xacro:macro>
</robot>
