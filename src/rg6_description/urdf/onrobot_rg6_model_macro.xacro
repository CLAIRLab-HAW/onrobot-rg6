<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
  <!-- <mimic> ist WIEDER DRIN (offizielle OnRobot-Multiplier, identisch zu den
       Werten, die der rg6_joint_state_broadcaster explizit publiziert). Ohne
       <mimic> animiert MoveIt im Planungs-Preview nur das Treibergelenk
       rg6_finger_joint - die 5 Folgegelenke stehen naemlich im SRDF nur als
       <passive_joint> (nicht in der gripper-Gruppe) und werden so nicht Teil
       der Planungs-Trajektorie. Mit <mimic> (URDF) + Aufnahme in die Gruppe
       (rg6_moveit_patch) klassifiziert MoveIt sie als mimic_joints_ und treibt
       sie aus rg6_finger_joint ab -> saubere Vorschau von Oeffnen/Schliessen.
       ROS2 robot_state_publisher (jazzy) wertet <mimic> ebenfalls aus, Foxglove
       laeuft ohnehin ueber /tf vom RSP.
       Historie: frueher hies es, <mimic> wuerde bei Foxglove "Meshes am Ursprung"
       ausloesen. Verursacher war aber das Original-URDF mit <material name="">
       (LEERER Materialname) - nicht <mimic>. Die leeren Namen sind laengst durch
       rg6_silver/rg6_black ersetzt, daher ist <mimic> sicher.
       <transmission> bleibt weg (ros2_control holt sich keine RG6-Transmision;
       der Greifer haengt am UR-Tool-Interface, nicht am ros2_controller). -->

  <xacro:macro name="outer_knuckle" params="prefix fingerprefix">
    <link name="${prefix}${fingerprefix}_outer_knuckle">
      <inertial>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
        <mass value="0.05" />
        <inertia ixx="1.0E-03" ixy="1.0E-06" ixz="1.0E-06" iyy="1.0E-03" iyz="1.0E-06" izz="1.0E-03" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://rg6_description/meshes/visual/outer_knuckle.stl" />
        </geometry>
        <material name="rg6_silver">
          <color rgba="0.6 0.6 0.6 1" />
        </material>
      </visual>
      <!-- collision bewusst weggelassen: 4-Gelenk-Schleife im URDF-Baum -> sonst
           Selbstkollision -> MoveIt-Planung schlaegt fehl. Greifer ist Anzeige-only. -->
    </link>
  </xacro:macro>

  <xacro:macro name="inner_knuckle" params="prefix fingerprefix">
    <link name="${prefix}${fingerprefix}_inner_knuckle">
      <inertial>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
        <mass value="0.05" />
        <inertia ixx="1.0E-03" ixy="1.0E-06" ixz="1.0E-06" iyy="1.0E-03" iyz="1.0E-06" izz="1.0E-03" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://rg6_description/meshes/visual/inner_knuckle.stl" />
        </geometry>
        <material name="rg6_silver">
          <color rgba="0.6 0.6 0.6 1" />
        </material>
      </visual>
      <!-- collision weggelassen (siehe outer_knuckle). -->
    </link>
  </xacro:macro>

  <xacro:macro name="inner_finger" params="prefix fingerprefix">
    <link name="${prefix}${fingerprefix}_inner_finger">
      <inertial>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
        <mass value="0.05" />
        <inertia ixx="1.0E-03" ixy="1.0E-06" ixz="1.0E-06" iyy="1.0E-03" iyz="1.0E-06" izz="1.0E-03" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://rg6_description/meshes/visual/inner_finger.stl" />
        </geometry>
        <material name="rg6_black">
          <color rgba="0.12 0.12 0.12 1" />
        </material>
      </visual>
      <!-- collision weggelassen (siehe outer_knuckle). -->
    </link>
  </xacro:macro>

  <xacro:macro name="inner_knuckle_joint" params="prefix fingerprefix reflect">
    <joint name="${prefix}${fingerprefix}_inner_knuckle_joint" type="revolute">
      <origin xyz="0 ${reflect * -0.012720} 0.159500" rpy="0 0 ${(reflect - 1) * pi / 2}" />
      <parent link="${prefix}onrobot_rg6_base_link" />
      <child link="${prefix}${fingerprefix}_inner_knuckle" />
      <axis xyz="1 0 0" />
      <limit lower="-0.628319" upper="0.628319" velocity="2.0" effort="1000" />
      <mimic joint="${prefix}finger_joint" multiplier="-1" offset="0" />
    </joint>
  </xacro:macro>

  <xacro:macro name="inner_finger_joint" params="prefix fingerprefix">
    <joint name="${prefix}${fingerprefix}_inner_finger_joint" type="revolute">
      <origin xyz="0 ${-(0.071447-0.024112)} ${0.201308-0.136813}" rpy="0 0 0" />
      <parent link="${prefix}${fingerprefix}_outer_knuckle" />
      <child link="${prefix}${fingerprefix}_inner_finger" />
      <axis xyz="1 0 0" />
      <limit lower="-0.872665" upper="0.872665" velocity="2.0" effort="1000" />
      <mimic joint="${prefix}finger_joint" multiplier="1" offset="0" />
    </joint>
  </xacro:macro>

  <xacro:include filename="$(find rg6_description)/urdf/onrobot_rg6.xacro" />

  <xacro:macro name="finger_joint" params="prefix">
    <joint name="${prefix}finger_joint" type="revolute">
      <origin xyz="0 -0.024112 0.136813" rpy="0 0 0" />
      <parent link="${prefix}onrobot_rg6_base_link" />
      <child link="${prefix}left_outer_knuckle" />
      <axis xyz="-1 0 0" />
      <limit lower="-0.628319" upper="0.628319" velocity="2.0" effort="1000" />
    </joint>
    <xacro:finger_joints prefix="${prefix}" fingerprefix="left" reflect="1.0"/>
  </xacro:macro>

  <xacro:macro name="right_outer_knuckle_joint" params="prefix">
    <joint name="${prefix}right_outer_knuckle_joint" type="revolute">
      <origin xyz="0 0.024112 0.136813" rpy="0 0 ${pi}" />
      <parent link="${prefix}onrobot_rg6_base_link" />
      <child link="${prefix}right_outer_knuckle" />
      <axis xyz="1 0 0" />
      <limit lower="-0.628319" upper="0.628319" velocity="2.0" effort="1000" />
      <mimic joint="${prefix}finger_joint" multiplier="-1" offset="0" />
    </joint>
    <xacro:finger_joints prefix="${prefix}" fingerprefix="right" reflect="-1.0"/>
  </xacro:macro>

  <xacro:macro name="onrobot_rg6" params="prefix">
    <xacro:onrobot_rg6_base_link prefix="${prefix}"/>
    <xacro:finger_links prefix="${prefix}" fingerprefix="left"/>
    <xacro:finger_links prefix="${prefix}" fingerprefix="right"/>
    <xacro:finger_joint prefix="${prefix}"/>
    <xacro:right_outer_knuckle_joint prefix="${prefix}"/>
  </xacro:macro>
</robot>
